# ===== Dominio (para Caddy / HTTPS) =====
DOMAIN=bot.tudominio.com

# ===== Postgres (interno al docker-compose) =====
POSTGRES_PASSWORD=cambiame_por_password_largo_y_random

# ===== Meta / Instagram =====
META_APP_SECRET=
META_VERIFY_TOKEN=elige_un_token_aleatorio
INSTAGRAM_PAGE_ACCESS_TOKEN=
INSTAGRAM_PAGE_ID=

# ===== Admin =====
ADMIN_API_KEY=cambiame_por_api_key_aleatoria

# ===== Email (opcional) =====
RESEND_API_KEY=
EMAIL_FROM=InstaBot <noreply@tudominio.com>
WELCOME_EMAIL_TEMPLATE=bienvenido.html
